        <div style={{ maxWidth: 1000, margin: '0 auto', display: 'flex', gap: 40, flexWrap: 'wrap', alignItems: 'center', justifyContent: 'center' }}>
          {[
            ['WITHOUT US', 'Cold-call billboard companies. Wait weeks. No proof your ad ran. Opaque pricing. Middlemen.', '#4B5563'],
            ['WITH STUDIO ARELLA', 'Book online in minutes. Pay securely. Ad goes live instantly. Track every impression in real time.', '#F97316'],
          ].map(([l,t,c]) => (
            <div key={l as string} style={{ display: 'flex', gap: 14, alignItems: 'flex-start', maxWidth: 420 }}>
              <span style={{ fontSize: 10, fontWeight: 800, letterSpacing: '0.1em', color: c as string, background: `${c}18`, border: `1px solid ${c}30`, padding: '3px 10px', borderRadius: 100, flexShrink: 0, marginTop: 2, textTransform: 'uppercase', whiteSpace: 'nowrap' }}>{l as string}</span>
              <p style={{ fontSize: 14, color: 'rgba(255,255,255,0.5)', lineHeight: 1.65, margin: 0 }}>{t as string}</p>
            </div>
          ))}
        </div>
