      {/* ═══ SERVICES ═══ */}
      <section id="services" style={{ padding: '96px 24px' }}>
        <div style={{ maxWidth: 1200, margin: '0 auto' }} ref={servicesReveal.ref}>
          <motion.div initial={{ opacity: 0, y: 24 }} animate={servicesReveal.visible ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.5 }} style={{ textAlign: 'center', marginBottom: 56 }}>
            <p style={{ fontSize: 12, fontWeight: 700, color: '#F97316', letterSpacing: '0.12em', textTransform: 'uppercase', marginBottom: 12 }}>What we offer</p>
            <h2 style={{ fontSize: 'clamp(28px,4vw,46px)', fontWeight: 900, letterSpacing: '-1px', color: '#fff', margin: '0 0 16px', lineHeight: 1.1 }}>
              Everything your brand needs<br />to get seen in Umuahia
            </h2>
            <p style={{ fontSize: 16, color: 'rgba(255,255,255,0.45)', maxWidth: 520, margin: '0 auto', lineHeight: 1.7 }}>
              From digital screen bookings to professional creative production — we handle every part of your advertising journey.
            </p>
          </motion.div>

          <div className="services-grid" style={{ display: 'grid', gridTemplateColumns: 'repeat(2,1fr)', gap: 20 }}>
            {SERVICES.map((s, i) => (
              <motion.div key={s.title} className="service-card"
                initial={{ opacity: 0, y: 24 }} animate={servicesReveal.visible ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.5, delay: i * 0.1 }}
                style={{ background: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: 20, padding: '32px 28px' }}>
                <div style={{ width: 52, height: 52, borderRadius: 14, background: s.bg, border: `1px solid ${s.border}`, display: 'flex', alignItems: 'center', justifyContent: 'center', marginBottom: 20 }}>
                  <s.Icon size={22} color={s.color} />
                </div>
                <h3 style={{ fontSize: 19, fontWeight: 800, color: '#fff', margin: '0 0 10px', letterSpacing: '-0.3px' }}>{s.title}</h3>
                <p style={{ fontSize: 14, color: 'rgba(255,255,255,0.5)', lineHeight: 1.7, margin: '0 0 20px' }}>{s.desc}</p>
                <Link href="/auth/register" style={{ display: 'inline-flex', alignItems: 'center', gap: 5, fontSize: 13, fontWeight: 700, color: s.color, textDecoration: 'none' }}>
                  Get started <FaArrowRight size={11} />
                </Link>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* ═══ HOW IT WORKS ═══ */}
      <section id="how" style={{ padding: '96px 24px', background: 'rgba(255,255,255,0.02)', borderTop: '1px solid rgba(255,255,255,0.05)', borderBottom: '1px solid rgba(255,255,255,0.05)' }}>
        <div style={{ maxWidth: 1200, margin: '0 auto' }} ref={howReveal.ref}>
          <motion.div initial={{ opacity: 0, y: 24 }} animate={howReveal.visible ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.5 }} style={{ textAlign: 'center', marginBottom: 64 }}>
            <p style={{ fontSize: 12, fontWeight: 700, color: '#F97316', letterSpacing: '0.12em', textTransform: 'uppercase', marginBottom: 12 }}>The process</p>
            <h2 style={{ fontSize: 'clamp(28px,4vw,46px)', fontWeight: 900, letterSpacing: '-1px', color: '#fff', margin: 0, lineHeight: 1.1 }}>
              From sign-up to screen<br />in four simple steps
            </h2>
          </motion.div>

          <div className="how-grid" style={{ display: 'grid', gridTemplateColumns: 'repeat(4,1fr)', gap: 0, position: 'relative' }}>
            {/* Connector */}
            <div style={{ position: 'absolute', top: 26, left: '12.5%', right: '12.5%', height: 1, background: 'linear-gradient(to right, transparent, rgba(249,115,22,0.3), rgba(249,115,22,0.3), transparent)', zIndex: 0 }} />
            {HOW.map((s, i) => (
              <motion.div key={s.n} initial={{ opacity: 0, y: 24 }} animate={howReveal.visible ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.5, delay: i * 0.12 }}
                style={{ padding: '0 20px 0', position: 'relative', zIndex: 1 }}>
                <div style={{ width: 52, height: 52, borderRadius: 15, background: i === 0 ? '#F97316' : 'rgba(249,115,22,0.1)', border: `2px solid ${i === 0 ? '#F97316' : 'rgba(249,115,22,0.2)'}`, display: 'flex', alignItems: 'center', justifyContent: 'center', marginBottom: 20 }}>
                  <span style={{ fontSize: 14, fontWeight: 900, color: i === 0 ? '#fff' : '#F97316' }}>{s.n}</span>
                </div>
                <h3 style={{ fontSize: 16, fontWeight: 800, color: '#fff', margin: '0 0 10px', letterSpacing: '-0.2px', lineHeight: 1.3 }}>{s.title}</h3>
                <p style={{ fontSize: 13, color: 'rgba(255,255,255,0.45)', lineHeight: 1.7, margin: 0 }}>{s.body}</p>
              </motion.div>
            ))}
          </div>

          <motion.div initial={{ opacity: 0, y: 16 }} animate={howReveal.visible ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.5, delay: 0.5 }}
            style={{ textAlign: 'center', marginTop: 56 }}>
            <Link href="/auth/register" className="cta-btn" style={{ display: 'inline-flex', alignItems: 'center', gap: 8, background: '#F97316', color: '#fff', padding: '14px 32px', borderRadius: 11, fontSize: 14, fontWeight: 800, textDecoration: 'none', boxShadow: '0 4px 20px rgba(249,115,22,0.35)' }}>
              Start now — it only takes a minute <FaArrowRight size={13} />
            </Link>
          </motion.div>
        </div>
      </section>

      {/* ═══ PRICING ═══ */}
      <section id="pricing" style={{ padding: '96px 24px' }}>
        <div style={{ maxWidth: 1200, margin: '0 auto' }} ref={plansReveal.ref}>
          <motion.div initial={{ opacity: 0, y: 24 }} animate={plansReveal.visible ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.5 }} style={{ textAlign: 'center', marginBottom: 56 }}>
            <p style={{ fontSize: 12, fontWeight: 700, color: '#F97316', letterSpacing: '0.12em', textTransform: 'uppercase', marginBottom: 12 }}>Pricing</p>
            <h2 style={{ fontSize: 'clamp(28px,4vw,46px)', fontWeight: 900, letterSpacing: '-1px', color: '#fff', margin: '0 0 14px', lineHeight: 1.1 }}>
              Simple, affordable, transparent
            </h2>
            <p style={{ fontSize: 16, color: 'rgba(255,255,255,0.45)', maxWidth: 480, margin: '0 auto', lineHeight: 1.7 }}>
              As part of Bems Group's commitment to affordability, advertising starts from as low as ₦1,000 per minute. No hidden fees.
            </p>
          </motion.div>

          <div className="plans-grid" style={{ display: 'grid', gridTemplateColumns: 'repeat(3,1fr)', gap: 16 }}>
            {PLANS.map((p, i) => (
              <motion.div key={p.name} className="plan-card"
                initial={{ opacity: 0, y: 24 }} animate={plansReveal.visible ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.5, delay: i * 0.08 }}
                style={{ background: p.popular ? 'rgba(249,115,22,0.08)' : 'rgba(255,255,255,0.03)', border: `1.5px solid ${p.popular ? '#F97316' : 'rgba(255,255,255,0.08)'}`, borderRadius: 18, padding: '28px 24px', position: 'relative' }}>
                {p.popular && (
                  <div style={{ position: 'absolute', top: -12, left: '50%', transform: 'translateX(-50%)', background: '#F97316', color: '#fff', fontSize: 10, fontWeight: 800, padding: '4px 14px', borderRadius: 100, whiteSpace: 'nowrap', letterSpacing: '0.08em' }}>
                    BEST VALUE
                  </div>
                )}
                <div className={p.popular ? 'shimmer' : ''} style={{ borderRadius: 10, padding: p.popular ? '2px' : '0', marginBottom: 2 }}>
                  <p style={{ fontSize: 15, fontWeight: 800, color: '#fff', margin: '0 0 3px' }}>{p.name}</p>
                </div>
                <p style={{ fontSize: 12, color: 'rgba(255,255,255,0.4)', margin: '0 0 18px' }}>
                  {p.minutes < 60 ? `${p.minutes} minute${p.minutes > 1 ? 's' : ''}` : `${p.minutes / 60} hour${p.minutes > 60 ? 's' : ''}`}
                </p>
                <p style={{ fontSize: 34, fontWeight: 900, color: p.popular ? '#F97316' : '#fff', margin: '0 0 4px', letterSpacing: '-1px' }}>
                  ₦{p.price.toLocaleString()}
                </p>
                <p style={{ fontSize: 11, color: 'rgba(255,255,255,0.3)', margin: '0 0 22px' }}>₦{p.perMin.toLocaleString()}/min</p>
                <Link href="/auth/register" style={{ display: 'block', textAlign: 'center', background: p.popular ? '#F97316' : 'rgba(255,255,255,0.07)', color: '#fff', border: p.popular ? 'none' : '1px solid rgba(255,255,255,0.12)', padding: '11px', borderRadius: 10, fontSize: 13, fontWeight: 700, textDecoration: 'none', transition: 'opacity 0.15s' }}
                  onMouseOver={e => (e.currentTarget.style.opacity = '0.85')} onMouseOut={e => (e.currentTarget.style.opacity = '1')}>
                  Book {p.name} slot
                </Link>
              </motion.div>
            ))}
          </div>

          <p style={{ textAlign: 'center', fontSize: 13, color: 'rgba(255,255,255,0.3)', marginTop: 24 }}>
            All plans billed once at booking. Secure payment via Paystack.
            <Link href="/auth/register" style={{ color: '#F97316', marginLeft: 6, textDecoration: 'none', fontWeight: 700 }}>Get started free →</Link>
          </p>
        </div>
