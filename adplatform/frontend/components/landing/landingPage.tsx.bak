                  <Link href="/auth/register" className="float-a" style={{ display: 'flex', alignItems: 'center', gap: 12, background: 'rgba(249,115,22,0.1)', border: '1px solid rgba(249,115,22,0.25)', borderRadius: 12, padding: '11px 14px', textDecoration: 'none', backdropFilter: 'blur(8px)' }}>
                    <div style={{ width: 34, height: 34, background: 'rgba(249,115,22,0.2)', borderRadius: 9, display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0 }}>
                      <FaBullhorn size={15} color="#F97316" />
                    </div>
                    <div>
                      <p style={{ fontSize: 12, fontWeight: 700, color: '#fff', margin: 0 }}>Start advertising</p>
                      <p style={{ fontSize: 10, color: 'rgba(255,255,255,0.4)', margin: '1px 0 0' }}>From ₦1,000/minute →</p>
                    </div>
                  </Link>
                  <Link href="/creative" className="float-b" style={{ display: 'flex', alignItems: 'center', gap: 12, background: 'rgba(124,58,237,0.1)', border: '1px solid rgba(124,58,237,0.25)', borderRadius: 12, padding: '11px 14px', textDecoration: 'none', backdropFilter: 'blur(8px)' }}>
                    <div style={{ width: 34, height: 34, background: 'rgba(124,58,237,0.2)', borderRadius: 9, display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0 }}>
                      <FaPaintbrush size={15} color="#A78BFA" />
                    </div>
                    <div>
                      <p style={{ fontSize: 12, fontWeight: 700, color: '#fff', margin: 0 }}>Need a creative team?</p>
                      <p style={{ fontSize: 10, color: 'rgba(255,255,255,0.4)', margin: '1px 0 0' }}>We design & film for you →</p>
                    </div>
                  </Link>
                </div>
              </div>
            </motion.div>

          </div>
        </div>
