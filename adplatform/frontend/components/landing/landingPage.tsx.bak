      {/* ═══ ABOUT / LOCATION ═══ */}
      <section style={{ padding: '96px 24px' }}>
        <div style={{ maxWidth: 1200, margin: '0 auto', display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 64, alignItems: 'center' }}>
          <div>
            <p style={{ fontSize: 12, fontWeight: 700, color: '#F97316', letterSpacing: '0.12em', textTransform: 'uppercase', marginBottom: 14 }}>About Studio Arella</p>
            <h2 style={{ fontSize: 'clamp(26px,3.5vw,40px)', fontWeight: 900, letterSpacing: '-0.8px', color: '#fff', margin: '0 0 18px', lineHeight: 1.15 }}>
              Umuahia's premier digital advertising screen
            </h2>
            <p style={{ fontSize: 15, color: 'rgba(255,255,255,0.5)', lineHeight: 1.8, margin: '0 0 20px' }}>
              Studio Arella is an initiative of <strong style={{ color: 'rgba(255,255,255,0.8)' }}>Bems Group</strong> — dedicated to helping businesses, brands, organisations, events, and campaigns gain greater visibility within and beyond Abia State.
            </p>
            <p style={{ fontSize: 15, color: 'rgba(255,255,255,0.5)', lineHeight: 1.8, margin: '0 0 32px' }}>
              Our digital screen is strategically located at <strong style={{ color: '#F97316' }}>Bems Junction, Finbars, Bende Road</strong> — one of Umuahia's highest-traffic points with thousands of daily road users. We are committed to making advertising accessible to every business, at any budget.
            </p>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 14 }}>
              {[
                { Icon: FaLocationDot, color: '#F97316', text: 'Bems Junction, Finbars, Bende Road, Umuahia, Abia State' },
                { Icon: FaPhone,       color: '#22c55e', text: '08164523926 — Diekolayomi Samuel Babatunde (Manager)' },
                { Icon: FaEnvelope,    color: '#60A5FA', text: 'Reach us through the support page for bookings enquiries' },
              ].map(({ Icon, color, text }) => (
                <div key={text} style={{ display: 'flex', alignItems: 'flex-start', gap: 12 }}>
                  <div style={{ width: 34, height: 34, borderRadius: 9, background: `${color}15`, border: `1px solid ${color}30`, display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0 }}>
                    <Icon size={14} color={color} />
                  </div>
                  <span style={{ fontSize: 13, color: 'rgba(255,255,255,0.55)', lineHeight: 1.6, marginTop: 8 }}>{text}</span>
                </div>
              ))}
            </div>
          </div>
          <div style={{ position: 'relative' }}>
            <div style={{ borderRadius: 20, overflow: 'hidden', border: '1px solid rgba(255,255,255,0.1)' }}>
              <img src="https://images.unsplash.com/photo-1511268559489-34b624fbfcf5?w=700&q=85&auto=format&fit=crop" alt="Digital billboard screen" style={{ width: '100%', height: 420, objectFit: 'cover', display: 'block', filter: 'brightness(0.8)' }} />
              <div style={{ position: 'absolute', inset: 0, background: 'linear-gradient(to top, rgba(10,10,10,0.7) 0%, transparent 50%)' }} />
              <div style={{ position: 'absolute', bottom: 20, left: 20, right: 20 }}>
                <div style={{ background: 'rgba(10,10,10,0.8)', backdropFilter: 'blur(12px)', border: '1px solid rgba(255,255,255,0.1)', borderRadius: 12, padding: '14px 18px' }}>
                  <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 4 }}>
                    <div style={{ width: 7, height: 7, borderRadius: '50%', background: '#22c55e', boxShadow: '0 0 6px #22c55e' }} />
                    <span style={{ fontSize: 11, fontWeight: 700, color: '#22c55e', letterSpacing: '0.06em' }}>SCREEN ONLINE</span>
                  </div>
                  <p style={{ fontSize: 13, fontWeight: 700, color: '#fff', margin: '0 0 2px' }}>Studio Arella — Bems Junction</p>
                  <p style={{ fontSize: 11, color: 'rgba(255,255,255,0.4)', margin: 0 }}>10ft × 6ft Digital LED Display · Umuahia, Abia State</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ═══ TESTIMONIALS ═══ */}
      <section style={{ padding: '80px 24px', background: 'rgba(255,255,255,0.02)', borderTop: '1px solid rgba(255,255,255,0.05)' }}>
        <div style={{ maxWidth: 1200, margin: '0 auto' }}>
          <div style={{ textAlign: 'center', marginBottom: 48 }}>
            <p style={{ fontSize: 12, fontWeight: 700, color: '#F97316', letterSpacing: '0.12em', textTransform: 'uppercase', marginBottom: 12 }}>What people say</p>
            <h2 style={{ fontSize: 'clamp(24px,3.5vw,38px)', fontWeight: 900, letterSpacing: '-0.8px', color: '#fff', margin: 0 }}>Trusted by Umuahia businesses</h2>
          </div>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit,minmax(300px,1fr))', gap: 18 }}>
            {[
              { name: 'Chukwuemeka Agu', role: 'Owner, Agu Supermarket — Umuahia', text: 'I listed my shop-front screen and had my first booking within the week. No phone calls, no negotiation — the ad was running. That\'s exactly what we needed.', color: '#F97316', initials: 'CA', avatar: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&q=80&auto=format&fit=crop&crop=face' },
              { name: 'Ngozi Obi', role: 'Marketing Officer, Abia SME', text: 'We booked two slots near Umuahia market for a product launch, uploaded our graphic, and it went live the same day. The real-time data was a bonus we didn\'t expect.', color: '#22c55e', initials: 'NO', avatar: 'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=80&h=80&q=80&auto=format&fit=crop&crop=face' },
              { name: 'Ifeanyi Nwosu', role: 'Brand Manager, Nwosu & Sons', text: 'No minimum spend, no agency fees. We spent ₦15,000 on a one-week booking and got proper impression reports. Will definitely scale this up.', color: '#60A5FA', initials: 'IN', avatar: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=80&h=80&q=80&auto=format&fit=crop&crop=face' },
            ].map(t => (
              <motion.div key={t.name} whileHover={{ y: -4 }} style={{ background: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.07)', borderRadius: 18, padding: '26px 24px' }}>
                <div style={{ display: 'flex', gap: 2, marginBottom: 14 }}>
                  {[...Array(5)].map((_, i) => <FaStar key={i} size={13} color="#F97316" />)}
                </div>
                <p style={{ fontSize: 14, color: 'rgba(255,255,255,0.6)', lineHeight: 1.75, margin: '0 0 22px', fontStyle: 'italic' }}>&ldquo;{t.text}&rdquo;</p>
                <div style={{ display: 'flex', alignItems: 'center', gap: 11 }}>
                  <img src={t.avatar} alt={t.name} style={{ width: 42, height: 42, borderRadius: '50%', objectFit: 'cover', border: `2px solid ${t.color}40`, flexShrink: 0 }} onError={e => (e.currentTarget.style.display = 'none')} />
                  <div>
                    <p style={{ fontSize: 13, fontWeight: 800, color: '#fff', margin: 0 }}>{t.name}</p>
                    <p style={{ fontSize: 11, color: 'rgba(255,255,255,0.35)', margin: '2px 0 0' }}>{t.role}</p>
                  </div>
                </div>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* ═══ DUAL CTA ═══ */}
      <section style={{ padding: '96px 24px' }}>
        <div style={{ maxWidth: 1100, margin: '0 auto' }}>
          <div className="dual-cta-grid" style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 18 }}>
            <div style={{ background: 'linear-gradient(135deg, rgba(249,115,22,0.14) 0%, rgba(249,115,22,0.04) 100%)', border: '1.5px solid rgba(249,115,22,0.25)', borderRadius: 22, padding: '44px 36px' }}>
              <div style={{ width: 54, height: 54, background: 'rgba(249,115,22,0.15)', border: '1px solid rgba(249,115,22,0.3)', borderRadius: 15, display: 'flex', alignItems: 'center', justifyContent: 'center', marginBottom: 22 }}>
                <FaBullhorn size={23} color="#F97316" />
              </div>
              <h3 style={{ fontSize: 24, fontWeight: 900, color: '#fff', margin: '0 0 12px', letterSpacing: '-0.4px' }}>I want to advertise</h3>
              <p style={{ fontSize: 14, color: 'rgba(255,255,255,0.5)', lineHeight: 1.7, margin: '0 0 28px' }}>
                Stop paying agency markups. Book your slot on Studio Arella directly — starting at ₦1,000. Upload your ad, pay online, and reach thousands at Bems Junction.
              </p>
              <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
                <Link href="/auth/register" className="cta-btn" style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', gap: 7, background: '#F97316', color: '#fff', padding: '13px 24px', borderRadius: 11, fontSize: 14, fontWeight: 800, textDecoration: 'none' }}>
                  Start advertising <FaArrowRight size={13} />
                </Link>
                <Link href="/auth/login" style={{ display: 'inline-flex', alignItems: 'center', gap: 7, color: 'rgba(255,255,255,0.4)', fontSize: 12, textDecoration: 'none', padding: '4px 0' }}>
                  Already have an account? Sign in →
                </Link>
              </div>
            </div>

            <div style={{ background: 'linear-gradient(135deg, rgba(124,58,237,0.12) 0%, rgba(124,58,237,0.03) 100%)', border: '1.5px solid rgba(124,58,237,0.2)', borderRadius: 22, padding: '44px 36px' }}>
              <div style={{ width: 54, height: 54, background: 'rgba(124,58,237,0.15)', border: '1px solid rgba(124,58,237,0.3)', borderRadius: 15, display: 'flex', alignItems: 'center', justifyContent: 'center', marginBottom: 22 }}>
                <FaPaintbrush size={23} color="#A78BFA" />
              </div>
              <h3 style={{ fontSize: 24, fontWeight: 900, color: '#fff', margin: '0 0 12px', letterSpacing: '-0.4px' }}>I need an ad created</h3>
              <p style={{ fontSize: 14, color: 'rgba(255,255,255,0.5)', lineHeight: 1.7, margin: '0 0 28px' }}>
                Our professional creative team designs graphics, flyers, and promotional videos for your business — visiting your location if needed. Affordable rates, outstanding results.
              </p>
              <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
                <Link href="/creative" className="cta-btn" style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', gap: 7, background: 'rgba(124,58,237,0.2)', border: '1px solid rgba(124,58,237,0.4)', color: '#A78BFA', padding: '13px 24px', borderRadius: 11, fontSize: 14, fontWeight: 800, textDecoration: 'none' }}>
                  Request creative team <FaArrowRight size={13} />
                </Link>
                <p style={{ fontSize: 12, color: 'rgba(255,255,255,0.25)', margin: '4px 0 0' }}>Call us: 08164523926</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ═══ FAQ ═══ */}
      <section id="faq" style={{ padding: '80px 24px', background: 'rgba(255,255,255,0.02)', borderTop: '1px solid rgba(255,255,255,0.05)' }}>
        <div style={{ maxWidth: 740, margin: '0 auto' }} ref={faqReveal.ref}>
          <motion.div initial={{ opacity: 0, y: 20 }} animate={faqReveal.visible ? { opacity: 1, y: 0 } : {}} transition={{ duration: 0.4 }} style={{ textAlign: 'center', marginBottom: 48 }}>
            <p style={{ fontSize: 12, fontWeight: 700, color: '#F97316', letterSpacing: '0.12em', textTransform: 'uppercase', marginBottom: 12 }}>Got questions?</p>
            <h2 style={{ fontSize: 'clamp(26px,4vw,40px)', fontWeight: 900, letterSpacing: '-0.8px', color: '#fff', margin: '0 0 12px' }}>Frequently asked questions</h2>
            <p style={{ fontSize: 14, color: 'rgba(255,255,255,0.4)', margin: 0 }}>
              Still unsure?{' '}
              <Link href="/support" style={{ color: '#F97316', fontWeight: 700, textDecoration: 'none' }}>Visit our support page</Link>
              {' '}or call <a href="tel:08164523926" style={{ color: '#F97316', fontWeight: 700, textDecoration: 'none' }}>08164523926</a>
            </p>
          </motion.div>
          <motion.div initial={{ opacity: 0 }} animate={faqReveal.visible ? { opacity: 1 } : {}} transition={{ duration: 0.4, delay: 0.15 }}
            style={{ background: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.07)', borderRadius: 18, padding: '0 28px' }}>
            {FAQS.map(f => <FAQItem key={f.q} q={f.q} a={f.a} />)}
          </motion.div>
        </div>
      </section>

      {/* ═══ FOOTER ═══ */}
      <footer style={{ borderTop: '1px solid rgba(255,255,255,0.06)', padding: '56px 24px 32px', background: '#050505' }}>
        <div style={{ maxWidth: 1200, margin: '0 auto' }}>
          <div className="footer-grid" style={{ display: 'grid', gridTemplateColumns: '2fr 1fr 1fr 1fr', gap: 48, marginBottom: 48 }}>
            <div>
              <Link href="/" style={{ display: 'inline-flex', alignItems: 'center', gap: 10, textDecoration: 'none', marginBottom: 18 }}>
                <div style={{ width: 34, height: 34, background: '#F97316', borderRadius: 8, display: 'flex', alignItems: 'center', justifyContent: 'center', fontWeight: 900, fontSize: 15, color: '#fff' }}>B</div>
                <div>
                  <p style={{ fontSize: 14, fontWeight: 800, color: '#fff', margin: 0 }}>Bems Screens</p>
                  <p style={{ fontSize: 9, color: 'rgba(255,255,255,0.3)', margin: 0, letterSpacing: '0.08em', textTransform: 'uppercase' }}>Studio Arella</p>
                </div>
              </Link>
              <p style={{ fontSize: 13, color: 'rgba(255,255,255,0.35)', lineHeight: 1.7, margin: '0 0 20px', maxWidth: 260 }}>
                Umuahia's premier digital advertising screen — helping businesses get the visibility they deserve. An initiative of Bems Group.
              </p>
              <div style={{ display: 'flex', gap: 8 }}>
                {[{ Icon: FaXTwitter, href: 'https://twitter.com' }, { Icon: FaLinkedinIn, href: 'https://linkedin.com' }, { Icon: FaInstagram, href: 'https://instagram.com' }].map(({ Icon, href }) => (
                  <a key={href} href={href} target="_blank" rel="noopener noreferrer" style={{ width: 32, height: 32, borderRadius: 8, background: 'rgba(255,255,255,0.06)', border: '1px solid rgba(255,255,255,0.08)', display: 'flex', alignItems: 'center', justifyContent: 'center', textDecoration: 'none', transition: 'background 0.15s' }}
                    onMouseOver={e => (e.currentTarget.style.background = 'rgba(249,115,22,0.15)')} onMouseOut={e => (e.currentTarget.style.background = 'rgba(255,255,255,0.06)')}>
                    <Icon size={13} color="rgba(255,255,255,0.5)" />
                  </a>
                ))}
              </div>
            </div>

            {[
              { title: 'Platform', links: [['Book Ad Slot','/book'],['Browse Plans','#pricing'],['Request Creative','/creative'],['My Calendar','/calendar'],['Dashboard','/dashboard']] },
              { title: 'Company', links: [['Services','#services'],['How it works','#how'],['FAQ','#faq'],['Support','/support'],['Sign in','/auth/login']] },
              { title: 'Contact', links: [['08164523926','tel:08164523926'],['Bems Junction, Umuahia','#'],['Register free','/auth/register'],['Privacy Policy','/support'],['Terms','/support']] },
            ].map(({ title, links }) => (
              <div key={title}>
                <p style={{ fontSize: 11, fontWeight: 800, color: '#fff', letterSpacing: '0.1em', textTransform: 'uppercase', margin: '0 0 16px' }}>{title}</p>
                <ul style={{ listStyle: 'none', margin: 0, padding: 0, display: 'flex', flexDirection: 'column', gap: 10 }}>
                  {links.map(([l, h]) => (
                    <li key={l}><Link href={h} style={{ fontSize: 13, color: 'rgba(255,255,255,0.35)', textDecoration: 'none', transition: 'color 0.15s' }}
                      onMouseOver={e => (e.currentTarget.style.color = '#F97316')} onMouseOut={e => (e.currentTarget.style.color = 'rgba(255,255,255,0.35)')}>{l}</Link></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <div style={{ borderTop: '1px solid rgba(255,255,255,0.05)', paddingTop: 22, display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: 12 }}>
            <p style={{ fontSize: 12, color: 'rgba(255,255,255,0.2)', margin: 0 }}>© {new Date().getFullYear()} Studio Arella · Bems Group · Proudly from Umuahia, Nigeria.</p>
            <p style={{ fontSize: 12, color: 'rgba(255,255,255,0.2)', margin: 0 }}>Managed by Diekolayomi Samuel Babatunde · 08164523926</p>
          </div>
        </div>
      </footer>

    </div>
  );
}
